{
  "name": "next-bff-three-tier",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "pnpm --filter @next-bff/client dev",
    "dev:client": "pnpm --filter @next-bff/client dev",
    "dev:bff": "pnpm --filter @next-bff/bff dev",
    "dev:server": "pnpm --filter @next-bff/server dev",
    "dev:all": "node scripts/dev-all.js",
    "stop:all": "node scripts/stop-all.js",
    "restart:all": "node scripts/restart-all.js",
    "build": "pnpm --filter @next-bff/client build",
    "build:client": "pnpm --filter @next-bff/client build",
    "build:bff": "pnpm --filter @next-bff/bff build",
    "build:server": "pnpm --filter @next-bff/server build",
    "build:all": "pnpm -r --if-present run build",
    "start": "pnpm --filter @next-bff/client start",
    "start:client": "pnpm --filter @next-bff/client start",
    "start:bff": "pnpm --filter @next-bff/bff start",
    "start:server": "pnpm --filter @next-bff/server start",
    "start:all": "pnpm -r --parallel --if-present run start",
    "test:bff": "pnpm --filter @next-bff/bff test",
    "test:bff:e2e": "pnpm --filter @next-bff/bff test:e2e",
    "lint": "pnpm lint:all",
    "lint:client": "eslint apps/client --max-warnings=0",
    "lint:bff": "eslint apps/bff --max-warnings=0",
    "lint:server": "eslint apps/server --max-warnings=0",
    "lint:all": "eslint . --max-warnings=0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "format:client": "prettier apps/client --write",
    "format:bff": "prettier apps/bff --write",
    "format:server": "prettier apps/server --write"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.59.0"
  }
}
