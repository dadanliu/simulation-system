# Shared
APP_ENV=development
NODE_ENV=development
LOG_LEVEL=log,warn,error
MONGODB_URI=mongodb://127.0.0.1:27017/next-bff-dev
MOCK_SEED_ENABLED=true
APP_VERSION=0.1.0
RELEASE_COMMIT_SHA=local
# RELEASE_NOTES_URL=https://github.com/example/next-bff/releases/tag/v0.1.0

# BFF
BFF_PORT=3001
BFF_PUBLIC_BASE_URL=http://localhost:3001
BACKEND_BASE_URL=http://localhost:3002
REDIS_URL=redis://127.0.0.1:6379
SESSION_TTL_SECONDS=86400
FILE_URL_SIGNING_SECRET=next-bff-dev-file-secret
FILE_URL_TTL_SECONDS=604800
FILE_PREVIEW_URL_TTL_SECONDS=3600
FILE_CACHE_THUMB_MAX_AGE_SECONDS=31536000
FILE_CACHE_THUMB_STALE_WHILE_REVALIDATE_SECONDS=86400
FILE_CACHE_DETAIL_MAX_AGE_SECONDS=31536000
FILE_CACHE_DETAIL_STALE_WHILE_REVALIDATE_SECONDS=86400
FILE_CACHE_PREVIEW_MAX_AGE_SECONDS=300
FILE_CACHE_PREVIEW_STALE_WHILE_REVALIDATE_SECONDS=60
COOKIE_SECURE=false
CSRF_ALLOWED_ORIGINS=http://localhost:3000
LOGIN_MAX_FAILURES_PER_USER=5
LOGIN_MAX_FAILURES_PER_IP=20
LOGIN_FAILURE_WINDOW_SECONDS=900
LOGIN_LOCK_SECONDS=600

# Backend mock service
SERVER_PORT=3002
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=.dev/uploads
LOCAL_UPLOAD_PUBLIC_BASE_URL=http://localhost:3002/uploads
UPLOAD_REGISTRY_PATH=.dev/upload-registry.json
# S3_BUCKET=next-bff-dev-assets
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=replace-me
# S3_SECRET_ACCESS_KEY=replace-me
# S3_PUBLIC_BASE_URL=https://cdn.example.com
# S3_UPLOAD_BASE_URL=https://next-bff-dev-assets.s3.us-east-1.amazonaws.com
# S3_KEY_PREFIX=uploads
# OSS_BUCKET=next-bff-dev-assets
# OSS_REGION=oss-cn-hangzhou
# OSS_ACCESS_KEY_ID=replace-me
# OSS_ACCESS_KEY_SECRET=replace-me
# OSS_PUBLIC_BASE_URL=https://cdn.example.com
# OSS_UPLOAD_BASE_URL=https://next-bff-dev-assets.oss-cn-hangzhou.aliyuncs.com
# OSS_KEY_PREFIX=uploads

# Client
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_SHOW_ENV_BADGE=true
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_RELEASE_COMMIT_SHA=local
# NEXT_PUBLIC_RELEASE_NOTES_URL=https://github.com/example/next-bff/releases/tag/v0.1.0
BFF_BASE_URL=http://localhost:3001
NEXT_INTERNAL_ORIGIN=http://127.0.0.1:3000

