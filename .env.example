# Shared
NODE_ENV=development
LOG_LEVEL=log,warn,error
MONGODB_URI=mongodb://127.0.0.1:27017/next-bff

# BFF
BFF_PORT=3001
BACKEND_BASE_URL=http://localhost:3002
REDIS_URL=redis://127.0.0.1:6379
SESSION_TTL_SECONDS=86400
COOKIE_SECURE=false
CSRF_ALLOWED_ORIGINS=http://localhost:3000
LOGIN_MAX_FAILURES_PER_USER=5
LOGIN_MAX_FAILURES_PER_IP=20
LOGIN_FAILURE_WINDOW_SECONDS=900
LOGIN_LOCK_SECONDS=600

# Backend mock service
SERVER_PORT=3002
STORAGE_DRIVER=local

# Client
BFF_BASE_URL=http://localhost:3001
NEXT_INTERNAL_ORIGIN=http://127.0.0.1:3000

# Production notes
# NODE_ENV=production
# COOKIE_SECURE=true
# MONGODB_URI=mongodb+srv://user:password@example.mongodb.net/next-bff
# BACKEND_BASE_URL=https://backend.example.com
# BFF_BASE_URL=https://bff.example.com
# NEXT_INTERNAL_ORIGIN=https://admin.example.com
