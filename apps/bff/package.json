{
  "name": "@next-bff/bff",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "pnpm --dir ../.. exec eslint apps/bff --max-warnings=0",
